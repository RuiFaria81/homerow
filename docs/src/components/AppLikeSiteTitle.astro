---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title" aria-label="Go to docs home">
  <img src="/logo-app.svg" alt="" aria-hidden="true" class="brand-logo" />
  <span class="brand-copy">
    <span class="brand-overline">Homerow</span>
    <span class="brand-title">
      <span>Mail</span>
      <span class="brand-beta">beta</span>
    </span>
  </span>
</a>

<style>
  .site-title {
    --brand-foreground: #1a1a2e;
    --brand-muted: #8e9196;
    --brand-hover-bg: #edf2fc;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    border-radius: 0.75rem;
    padding: 0.25rem 0.375rem;
    color: var(--brand-foreground);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }

  .site-title:hover {
    background: var(--brand-hover-bg);
  }

  .site-title:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .brand-logo {
    width: auto;
    height: 2rem;
    max-width: 40px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand-copy {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-overline {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-muted);
    opacity: 0.75;
  }

  .brand-title {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--brand-foreground);
  }

  .brand-beta {
    font-size: 9px;
    font-weight: 400;
    color: var(--brand-muted);
    opacity: 0.75;
  }

  :global(html[data-theme='dark']) .site-title {
    --brand-foreground: #f0f2f5;
    --brand-muted: #6b7280;
    --brand-hover-bg: rgba(255, 255, 255, 0.05);
  }
</style>
